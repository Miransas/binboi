# Core relay / control plane configuration.
# These variables are enough for local tunneling without any third-party API.
BINBOI_API_ADDR=:8080
BINBOI_TUNNEL_ADDR=:8081
BINBOI_PROXY_ADDR=:8000
BINBOI_BASE_DOMAIN=binboi.localhost
BINBOI_PUBLIC_SCHEME=http
BINBOI_PUBLIC_PORT=8000
BINBOI_DATABASE_PATH=./binboi.db

# Optional relay metadata used in the dashboard and request views.
BINBOI_INSTANCE_NAME=Binboi Local
BINBOI_DEFAULT_REGION=local

# Postgres is required when you want shared auth, domains, billing, and web-backed account data.
BINBOI_AUTH_DATABASE_URL=postgresql://binboi:binboi@localhost:5432/binboi?sslmode=disable

# Some server paths also fall back to DATABASE_URL if BINBOI_AUTH_DATABASE_URL is empty.
DATABASE_URL=postgresql://binboi:binboi@localhost:5432/binboi?sslmode=disable

# CLI defaults for local development and CI usage.
BINBOI_API_URL=http://127.0.0.1:8080
BINBOI_SERVER_ADDR=127.0.0.1:8081
BINBOI_AUTH_TOKEN=replace-with-generated-access-token
BINBOI_DASHBOARD_URL=http://127.0.0.1:3000

# Legacy compatibility alias accepted by the CLI.
BINBOI_TOKEN=
