# Core web app configuration.
# DATABASE_URL enables database-backed auth, invites, access tokens, and billing state.
DATABASE_URL=postgresql://binboi:binboi@localhost:5432/binboi?sslmode=disable
AUTH_SECRET=replace-with-a-long-random-string

# Public browser-facing control plane addresses.
NEXT_PUBLIC_BINBOI_API_BASE=http://127.0.0.1:8080
NEXT_PUBLIC_BINBOI_WS_BASE=ws://127.0.0.1:8080

# Optional server-side overrides for the Next.js app when it runs outside the browser network.
BINBOI_API_BASE=http://core:8080
BINBOI_WS_BASE=ws://core:8080

# Optional GitHub OAuth. Only needed if you want "Sign in with GitHub".
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional OpenAI integration. Only needed for the dashboard assistant/API helper.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional Paddle billing. Needed only for paid plans, checkout, plan changes, and webhook sync.
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRO_PRICE_ID=
PADDLE_PRO_PRODUCT_ID=
PADDLE_SCALE_PRICE_ID=
PADDLE_SCALE_PRODUCT_ID=
PADDLE_API_BASE_URL=https://api.paddle.com
