version: '3.9'

services:
  elasiya-server:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: elasiya-server
    ports:
      - "8080:8080"           # dışarıdan 8080 → container 8080
    environment:
      - PORT=8080             # veya başka port
    restart: unless-stopped
    volumes:
      - ./config:/app/config  # config dosyası varsa
    command: ["--port", "8080"]  # istersen buradan değiştir