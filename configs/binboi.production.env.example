# Binboi Go control plane - production/staging oriented example

BINBOI_API_ADDR=0.0.0.0:8080
BINBOI_TUNNEL_ADDR=0.0.0.0:8081
BINBOI_PROXY_ADDR=0.0.0.0:80
BINBOI_PROXY_TLS_ADDR=0.0.0.0:443

BINBOI_BASE_DOMAIN=binboi.example.com
BINBOI_PUBLIC_SCHEME=https
BINBOI_PUBLIC_PORT=443

BINBOI_DATABASE_PATH=/var/lib/binboi/binboi.db
BINBOI_AUTH_DATABASE_URL=postgresql://binboi:replace-me@postgres.internal:5432/binboi?sslmode=require

BINBOI_ACME_CACHE_DIR=/var/lib/binboi/acme
BINBOI_ACME_EMAIL=ops@example.com

BINBOI_ALLOW_PREVIEW_MODE=false

BINBOI_READ_HEADER_TIMEOUT=10s
BINBOI_READ_TIMEOUT=30s
BINBOI_WRITE_TIMEOUT=60s
BINBOI_IDLE_TIMEOUT=90s
BINBOI_SHUTDOWN_TIMEOUT=10s

BINBOI_EVENT_LIMIT=100
BINBOI_REQUEST_LIMIT=200
BINBOI_STORED_EVENT_LIMIT=5000
BINBOI_STORED_REQUEST_LIMIT=20000
BINBOI_AUDIT_EXPORT_LIMIT=10000
BINBOI_EXPORT_MAX_BYTES=8388608
BINBOI_EVENT_RETENTION_MAX_AGE=720h
BINBOI_REQUEST_RETENTION_MAX_AGE=720h

BINBOI_DOMAIN_VERIFY_INTERVAL=60s
BINBOI_DOMAIN_VERIFY_BATCH_SIZE=50
BINBOI_DOMAIN_LOOKUP_TIMEOUT=5s

BINBOI_API_RATE_LIMIT=240
BINBOI_API_RATE_BURST=60
BINBOI_PROXY_RATE_LIMIT=1200
BINBOI_PROXY_RATE_BURST=240

# Optional CLI-facing defaults for operators on the same host.
BINBOI_API_URL=https://api.binboi.example.com
BINBOI_SERVER_ADDR=binboi.example.com:8081
BINBOI_DASHBOARD_URL=https://app.binboi.example.com/dashboard/access-tokens
